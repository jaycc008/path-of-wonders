# Landing page (Vite + React Router) environment variables.
#
# Copy this file to `.env` for local development. For Vercel deployments, set
# the same variables in Vercel Project Settings -> Environment Variables
# (Production and Preview environments separately).
#
# Vite reads any variable prefixed with `VITE_` and exposes it to the browser
# bundle. Do NOT put secrets here -- everything here is public to anyone who
# inspects the built JS.

# === API ===
# Base URL of the FastAPI backend, INCLUDING the trailing slash. The landing's
# axios client appends paths like `stripe/price/...` without a leading slash.
#  - local:      http://api.pathofwonders.local:8000/api/v1/
#  - test/preview: https://api-test.pathofwonders.com/api/v1/
#  - prod:       https://api.pathofwonders.com/api/v1/
VITE_API_BASE_URL=http://api.pathofwonders.local:8000/api/v1/

# === Cookies ===
# Domain the API sets the `auth_token` cookie on. Must be the parent domain
# shared by API and frontends so the cookie crosses subdomains.
#  - local: .pathofwonders.local
#  - test/prod: .pathofwonders.com
VITE_COOKIE_DOMAIN=.pathofwonders.local

# === Portal cross-links ===
# Where to send users when they click Sign In / Sign Up / My Learnings from
# the landing site. These are URLs on the portal app.
#  - local:      http://lms.pathofwonders.local:3000/...
#  - test:       https://portal-test.pathofwonders.com/...
#  - prod:       https://portal.pathofwonders.com/...
VITE_LOGIN_URL=http://lms.pathofwonders.local:3000/signin
VITE_SIGNUP_URL=http://lms.pathofwonders.local:3000/signup
VITE_MY_LEARNING_URL=http://lms.pathofwonders.local:3000/student/learnings

# === Google OAuth ===
# OAuth Client ID for "Sign in with Google" (the public half of the OAuth
# credential pair). The corresponding client SECRET lives on the API only.
# Get this from Google Cloud Console -> APIs & Services -> Credentials.
VITE_GOOGLE_CLIENT_ID=
